// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// =========================== user model ==================================

model User {
  id          String   @id @default(cuid())
  supabaseId  String   @unique // Correspond au user_id de Supabase Auth
  email       String   @unique
  role        Role     @default(VIEWER)
  permissions String[] // ex: ["manage_content", "upload_media"] [2]
  isActive    Boolean  @default(true)
  lastLogin   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("admin_users")
}

enum Role {
  ADMIN
  EDITOR
  VIEWER
}

// =========================== CMS core models =============================

model Locale {
  code      String   @id // ex: "fr", "en"
  name      String
  isDefault Boolean  @default(false)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  pageLocales PageLocale[]

  @@map("cms_locales")
}

enum PageType {
  HOME
  GENERIC
}

enum ContentStatus {
  DRAFT
  REVIEWED
  MACHINE_TRANSLATED
  PUBLISHED
}

model Page {
  id       String   @id @default(cuid())
  slugBase String   @unique // stable slug used across locales, ex: "home", "about"
  type     PageType @default(GENERIC)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  locales PageLocale[]

  @@map("cms_pages")
}

model PageLocale {
  id              String        @id @default(cuid())
  pageId          String
  localeCode      String
  title           String
  metaTitle       String?
  metaDescription String?
  blocksVersion   Int           @default(1)
  blocksJson      Json
  status          ContentStatus @default(DRAFT)
  publishedAt     DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  updatedById     String?

  page   Page   @relation(fields: [pageId], references: [id], onDelete: Cascade)
  locale Locale @relation(fields: [localeCode], references: [code])
  translationJobs TranslationJob[]

  @@unique([pageId, localeCode])
  @@index([localeCode, status])
  @@map("cms_page_locales")
}

model Asset {
  id        String   @id @default(cuid())
  url       String
  mime      String?
  width     Int?
  height    Int?
  sizeBytes Int?
  alt       String?
  createdAt DateTime @default(now())
  createdById String?

  @@map("cms_assets")
}

model AuditLog {
  id              String   @id @default(cuid())
  actorSupabaseId String?
  actorUserId     String?
  action          String
  entityType      String
  entityId        String
  diff            Json?
  createdAt       DateTime @default(now())

  @@index([entityType, entityId])
  @@map("cms_audit_logs")
}

enum TranslationJobStatus {
  PENDING
  RUNNING
  SUCCEEDED
  FAILED
}

model TranslationJob {
  id               String               @id @default(cuid())
  pageLocaleId     String
  sourceLocaleCode String
  targetLocaleCode String
  provider         String?
  status           TranslationJobStatus @default(PENDING)
  attempts         Int                  @default(0)
  lastError        String?
  payload          Json?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  pageLocale PageLocale @relation(fields: [pageLocaleId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([targetLocaleCode])
  @@map("cms_translation_jobs")
}

// =========================== character model ==================================
model Character {
  id          String   @id @default(cuid())
  slug        String   @unique // ex: "zaiire-kongo"
  name        String
  title       String
  origin      String
  color       String   // Pour les thèmes visuels [4]
  image       String   // URL de l'image principale
  description String   @db.Text
  powers      String[] // Tableau de pouvoirs [5]
  powerIcons  String[] // Noms des icônes Lucide (ex: "Zap", "Crown") [4]

  // Relations
  books       Book []    @relation("BookCharacters")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("characters")
}

// =========================== book model ==================================
model Book {
   id              String   @id @default(cuid())
  title           String
  subtitle        String?
  description     String   @db.Text
  fullDescription String   @db.Text
  priceInCents    Int      // Stocker en cents pour éviter les erreurs de flottants [6]
  coverImage      String
  accentColor     String
  format          String   // ex: "Paperback"
  pages           Int
  tags            String[] // ex: ["African Mythology", "Fantasy"] [6]
  
  // Relations
  characters      Character[] @relation("BookCharacters")
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@map("books")
}
