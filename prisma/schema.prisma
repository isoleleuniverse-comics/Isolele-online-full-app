// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}
model Language {
  code        String @id
  name        String
  nativeName  String

  enabled     Boolean @default(true)
  isDefault   Boolean @default(false)

  createdAt   DateTime @default(now())

  articles    Article[]
}

model TranslationGroup {
  id String @id @default(cuid())

  sourceLocale String

  targetLocales Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  articles Article[]
}

model Article {
  id String @id @default(cuid())

  translationGroupId String
  translationGroup TranslationGroup @relation(fields: [translationGroupId], references: [id])

  locale String
  language Language @relation(fields: [locale], references: [code])

  slug String

  title String
  excerpt String?

  coverImage String?

  blocksJson Json

  status ArticleStatus @default(DRAFT)

  translationStatus TranslationStatus @default(UP_TO_DATE)

  sourceVersion Int @default(1) 
  translatedFromVersion Int?

  seoTitle String? 
  seoDescription String?

  publishedAt DateTime?

  createdAt DateTime @default(now()) 
  updatedAt DateTime @updatedAt

  @@unique([translationGroupId, locale])
  @@unique([locale, slug])

  @@index([locale])
  @@index([status])
}

enum ArticleStatus {
  DRAFT
  REVIEW
  PUBLISHED
  ARCHIVED
}

enum TranslationStatus {
  UP_TO_DATE
  OUTDATED
  MACHINE_TRANSLATED
  NEEDS_REVIEW
}