                        className="w-full px-4 py-3 rounded-lg text-sm outline-none transition-all resize-none"
                        style={{ backgroundColor: "var(--isolele-bg)", color: "var(--isolele-text)", border: "1px solid rgba(212,175,55,0.2)" }}
                      />
                    </div>
                    <motion.button
