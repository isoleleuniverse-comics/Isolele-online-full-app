    book_zaiire_title: "ZAIIRE",
    book_zaiire_subtitle: "UMUHLOLI WESIPHETHO",
    book_zaiire_desc: "Enziwe enhliziyweni yoMbuso wakwa-Kongo, uMuhloli Wesiphetho awuzange wenziwe ukuthi ugqokwe. Wenziwe ukuthi ukhethe. Wadluliswa emakhulwini eminyaka omlilo, izimpi, nokuthula, uthwala umphefumlo wayo yonke inkosi eyachitha igazi labantu bayo nayo yonke indlovukazi eyabamba umhlaba ndawonye ngezandla ezingenalutho. Lapho ithola uZaiire, ayikhanyi. Iyavuka.",
    book_zaiire_button: "THOLA U-ZAIIRE",
    
    book_kufu_tag: "KUFU: UMDLALO WOMOQO",
    book_kufu_title: "KUFU",
    book_kufu_subtitle: "UMDLALO OSEMTHETHENI WOMHLABA WE-ISOLELE",
    book_kufu_desc: "Lo akusiyona nje umdlalo wamakhadi. Kungumkhosi. Qoqa amaqhawe akho. Yakha umbuso wakho. Dlula zonke izimbangi etafuleni. Kodwa ukuthatha umqoqo kunye ndlela kuphela yokuwina. Kumele uphakamise izwi lakho usho igama lenkosi ngokuzwakalayo. Bese kuthi umuntu abeke umgexo entanyeni yakho. Hhayi ngesandla sakho. Ngesandla somunye. Ngoba inkosi yangempela ayithweswa umqoqo iyodwa. I-KUFU yilapho ubukhosi base-Afrika buba yinto oyizwa ngezandla zakho, oyizwa ngezwi lakho, futhi oyithwala entanyeni yakho. Wonke umdlalo ungumgcotsho. Wonke owinile uyinkosi.",
    book_kufu_button: "HLOLA UMDLALO",
    
