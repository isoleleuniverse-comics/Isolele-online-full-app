                  <div className="flex gap-1">
                    {[...Array(review.rating)].map((_, i) => (
                      <Star key={i} size={14} fill={book.accentColor} color={book.accentColor} />
                    ))}
                  </div>
                </div>
                <p className="text-sm leading-relaxed" style={{ color: currentTheme.colors.textSecondary }}>
                  {review.text}
