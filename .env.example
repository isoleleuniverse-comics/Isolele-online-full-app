# Gemini API Configuration (Free)
NEXT_PUBLIC_GEMINI_API_KEY=your_gemini_api_key_here

# Google Cloud Translation API (Optional - requires billing)
GOOGLE_CLOUD_PROJECT_ID=your_gcp_project_id_here
GOOGLE_TRANSLATE_API_KEY=your_google_translate_api_key_here

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Stripe Configuration
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key_here
STRIPE_SECRET_KEY=your_stripe_secret_key_here

# AI SDK Configuration
AI_GATEWAY_API_KEY=optional_ai_gateway_key_here

# OpenAI (Optional fallback)
OPENAI_API_KEY=optional_openai_key_here

# Environment
NODE_ENV=development
NEXT_PUBLIC_API_URL=http://localhost:3000
