# =============================================================
# ISOLELE - ONLINE FULL APP
# Copier ce fichier en .env.local et remplir les valeurs
# NE JAMAIS commiter .env.local sur git
# =============================================================

# -------------------------------------------------------------
# SUPABASE (Base de données & Auth)
# https://supabase.com/dashboard/project/_/settings/api
# -------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_JWT_SECRET=

# Supabase Postgres Direct
POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=
POSTGRES_HOST=

# -------------------------------------------------------------
# STRIPE (Paiements)
# https://dashboard.stripe.com/apikeys
# -------------------------------------------------------------
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# -------------------------------------------------------------
# XAI / GROK (IA Chatbot)
# https://console.x.ai
# -------------------------------------------------------------
XAI_API_KEY=

# -------------------------------------------------------------
# GOOGLE GEMINI (Traduction IA & Chatbot)
# https://aistudio.google.com/app/apikey
# -------------------------------------------------------------
GOOGLE_GEMINI_API_KEY=
NEXT_PUBLIC_GEMINI_API_KEY=
GEMINI_API_KEY=

# -------------------------------------------------------------
# GOOGLE TRANSLATE (Traduction Cloud)
# https://console.cloud.google.com/apis/library/translate.googleapis.com
# -------------------------------------------------------------
GOOGLE_TRANSLATE_API_KEY=
GOOGLE_CLOUD_PROJECT_ID=

# -------------------------------------------------------------
# EMAILJS (Formulaire de contact & Factures)
# https://www.emailjs.com
# -------------------------------------------------------------
NEXT_PUBLIC_EMAILJS_SERVICE_ID=
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=
EMAILJS_SERVICE_ID=
EMAILJS_TEMPLATE_ID=
EMAILJS_PUBLIC_KEY=

# -------------------------------------------------------------
# RESEND (Emails transactionnels)
# https://resend.com/api-keys
# -------------------------------------------------------------
RESEND_API_KEY=

# -------------------------------------------------------------
# GITHUB (Sauvegarde & Déploiement admin)
# https://github.com/settings/tokens
# -------------------------------------------------------------
GITHUB_TOKEN=
GITHUB_REPO=isoleleuniverse-comics/Isolele-online-full-app

# -------------------------------------------------------------
# VERCEL (Déploiement depuis panel admin)
# https://vercel.com/account/tokens
# -------------------------------------------------------------
VERCEL_TOKEN=
VERCEL_PROJECT_ID=prj_qRG9HFkQTuqquv3fHGVOl41PHH7Z

# -------------------------------------------------------------
# INDEXNOW (SEO - Réindexation)
# -------------------------------------------------------------
INDEXNOW_API_KEY=isolele-indexnow-key

# -------------------------------------------------------------
# ADMIN PANEL
# -------------------------------------------------------------
ADMIN_INIT_SECRET=

# -------------------------------------------------------------
# APP
# -------------------------------------------------------------
NEXT_PUBLIC_BASE_URL=https://your-domain.vercel.app
NODE_ENV=development
