          background: `linear-gradient(90deg, transparent, ${currentTheme.colors.accentPrimary}, transparent)`,
        }}
      />

      <div className="max-w-7xl mx-auto">
        <ShowcaseHeader
          labels={{
            eyebrow: charactersShowcase.eyebrow,
