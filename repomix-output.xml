"use client";

import type { ArticleStatus } from "@/generated/prisma";
import { Button } from "@/components/ui/button";
import { cn } from "@/shared/lib/utils";
import { useArticleEditor } from "./articles-editor-context";

const previewModes = [
    { value: "edit", label: "Edit" },
    { value: "split", label: "Split" },
    { value: "preview", label: "Preview" },
] as const;

const statuses: ArticleStatus[] = ["DRAFT", "REVIEW", "PUBLISHED", "ARCHIVED"];

function getStatusLabel(status: ArticleStatus) {
    if (status === "DRAFT") return "Brouillon";
    if (status === "REVIEW") return "En revision";
    if (status === "PUBLISHED") return "Publie";
    return "Archive";
}

export function ArticlesEditorTopbar() {
    const {
        articleLocale,
        title,
        status,
        previewMode,
        setPreviewMode,
        saveArticle,
        changeStatus,
        isSaving,
        isStatusPending,
    } = useArticleEditor();

    return (
        <header className="border-b border-white/10 bg-[#12100d]/88 backdrop-blur">
            <div className="flex flex-col gap-4 px-4 py-4 lg:px-6 xl:flex-row xl:items-center xl:justify-between">
                <div className="min-w-0">
                    <p className="text-[11px] uppercase tracking-[0.32em] text-[#c9a84c]">
                        ISOLELE Editorial Studio
                    </p>
                    <div className="mt-2 flex flex-wrap items-center gap-3">
                        <h1 className="truncate font-serif text-2xl font-light text-[#f6f0e8]">
                            {title.trim() || "Nouvel article"}
                        </h1>
                        <span className="rounded-full border border-white/10 bg-white/5 px-3 py-1 text-[11px] uppercase tracking-[0.2em] text-[#b9ac9a]">
                            {articleLocale}
                        </span>
                        <span className="rounded-full border border-[#3d3220] bg-[#1b1711] px-3 py-1 text-[11px] uppercase tracking-[0.2em] text-[#d7be7e]">
                            {getStatusLabel(status)}
                        </span>
                    </div>
                </div>

                <div className="flex flex-col gap-3 xl:items-end">
                    <div className="inline-flex w-fit rounded-full border border-white/10 bg-black/20 p-1">
                        {previewModes.map((mode) => (
                            <button
                                key={mode.value}
                                type="button"
                                onClick={() => setPreviewMode(mode.value)}
                                className={cn(
                                    "rounded-full px-4 py-2 text-xs uppercase tracking-[0.24em] transition",
                                    previewMode === mode.value
                                        ? "bg-[#d2b26d] text-[#16120d]"
                                        : "text-[#a99c8a] hover:text-[#f2ede6]",
                                )}
                            >
                                {mode.label}
                            </button>
                        ))}
                    </div>

                    <div className="flex flex-wrap items-center gap-2">
                        {statuses.map((nextStatus) => (
                            <Button
                                key={nextStatus}
                                type="button"
                                variant={status === nextStatus ? "secondary" : "ghost"}
                                size="sm"
                                onClick={() => changeStatus(nextStatus)}
                                disabled={isStatusPending}
                                className={cn(
                                    "rounded-full border border-white/10 bg-transparent px-3 text-xs uppercase tracking-[0.2em]",
                                    status === nextStatus && "border-[#5b4b30] bg-[#201a11] text-[#f4e1b0]",
                                )}
                            >
                                {getStatusLabel(nextStatus)}
                            </Button>
                        ))}

                        <Button
                            type="button"
                            size="sm"
                            onClick={saveArticle}
                            disabled={isSaving}
                            className="rounded-full bg-[#d2b26d] px-4 text-[#16120d] hover:bg-[#e3c57f]"
                        >
                            {isSaving ? "Sauvegarde..." : "Sauvegarder"}
                        </Button>
                    </div>
                </div>
            </div>
        </header>
    );
}
</file>

