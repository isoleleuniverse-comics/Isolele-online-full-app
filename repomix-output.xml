        blurDataURL="data:image/jpeg;base64,"
        loading="lazy"
      />

      <div
        className="absolute inset-0"
        style={{
          background: `linear-gradient(180deg, transparent 50%, ${character.color}80 85%, rgba(0,0,0,0.9) 100%)`,
