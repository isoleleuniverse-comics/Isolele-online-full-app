                                    <span className="text-[#d6b870]">/</span>
                                    <span>{readingTime} min read</span>
                                </div>
                            </div>
                        </div>
                    </header>

                    <ArticleBlockRenderer blocks={blocks} />
                </article>
            </div>
        </aside>
    );
}
