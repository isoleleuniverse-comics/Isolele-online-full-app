<file path="src/features/comics/ui/sections/comic-carousel-section/comic-card.tsx">
import Image from "next/image";
import { ShoppingBag } from "lucide-react";
import type { ComicBook, TranslationFn } from "@/features/comics/model/comics.types";

interface ComicCardProps {
  book: ComicBook;
  isFrench: boolean;
  t: TranslationFn;
}

function getLocalizedTitle(book: ComicBook, isFrench: boolean, t: TranslationFn): string {
  if (book.titleKey) return t(book.titleKey);
  return isFrench ? (book.titleFr ?? book.titleEn ?? "") : (book.titleEn ?? book.titleFr ?? "");
}

function getLocalizedDescription(book: ComicBook, isFrench: boolean, t: TranslationFn): string {
  if (book.descKey) return t(book.descKey);
  return isFrench ? (book.descFr ?? book.descEn ?? "") : (book.descEn ?? book.descFr ?? "");
}

export function ComicCard({ book, isFrench, t }: ComicCardProps) {
  const title = getLocalizedTitle(book, isFrench, t);
  const description = getLocalizedDescription(book, isFrench, t);

  return (
    <article className="h-full overflow-hidden rounded-xl border border-border/60 bg-card transition-all hover:border-[var(--isolele-accent)]/60 hover:shadow-lg hover:shadow-[var(--isolele-accent)]/15">
      <div className="relative h-72 overflow-hidden bg-black/20">
        <Image
          src={book.image}
          alt={title}
          fill
          className="object-cover transition-transform duration-500 hover:scale-105"
        />
        <div className="absolute inset-0 bg-gradient-to-t from-black/70 via-black/10 to-transparent" />
        <div className="absolute right-3 top-3 rounded-full bg-[var(--isolele-accent)] px-3 py-1 text-sm font-bold text-black">
          ${book.price.toFixed(2)}
        </div>
      </div>

      <div className="flex h-[220px] flex-col p-4">
        <span className="mb-2 text-xs font-bold uppercase tracking-wider text-[var(--isolele-accent)]">
          {book.category}
        </span>
        <h3 className="mb-2 text-base font-bold leading-tight text-foreground">{title}</h3>
        <p className="mb-4 flex-1 text-sm text-foreground/70">{description}</p>

        <button className="inline-flex w-full items-center justify-center gap-2 rounded-lg bg-[var(--isolele-accent)] px-4 py-2 text-sm font-bold text-black transition hover:opacity-90">
          <ShoppingBag size={16} />
          {isFrench ? "Lire" : "Read"}
        </button>
      </div>
    </article>
  );
}
